# ============================================================
# SIRI-AI JTM — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file — it contains secrets.
# ============================================================

# --- Database (Supabase Postgres via connection pooler) ---
# Get this from: Supabase Dashboard → Project Settings → Database → Connection String
# Use the pooler URL (port 6543) for IPv4 compatibility and serverless environments.
# Format: postgresql://postgres.[project-ref]:[url-encoded-password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&prepared_statements=false
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_URL_ENCODED_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&prepared_statements=false&connection_limit=1"

# --- Supabase Project (for future Supabase Auth/Storage integration) ---
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY"
SUPABASE_PROJECT_REF="YOUR_PROJECT_REF"

# --- NextAuth (PRD §12 — JWT-based session, 8h expiry) ---
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_URL="https://your-deployment-url.netlify.app"
NEXTAUTH_SECRET="generate-a-strong-random-secret-here"

# --- Z.AI GLM (PRD §10 — server-side only) ---
# The z-ai-web-dev-sdk auto-discovers the API key from the ZAI_API_KEY env var.
# Get your key from: https://z.ai
ZAI_API_KEY="your-zai-api-key"
